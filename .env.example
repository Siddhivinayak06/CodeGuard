# ==============================================
# CodeGuard — Environment Variables Template
# Copy this file to .env and fill in your values.
# Compatible with: Coolify, Dokploy, or any Docker host.
# ==============================================

# ------------------------------
# 1. Application
# ------------------------------
NODE_ENV=production

# Frontend origin (for CORS allowlist on backend)
CORS_ORIGIN=https://codeguard.yourdomain.com

# Public URL the browser uses to reach the backend API
NEXT_PUBLIC_API_URL=https://api.codeguard.yourdomain.com

# Public URL of the frontend itself
NEXT_PUBLIC_SITE_URL=https://codeguard.yourdomain.com

# ------------------------------
# 2. Secrets
# ------------------------------
JWT_SECRET=your-jwt-secret-at-least-32-characters-long

# ------------------------------
# 3. Database (Supabase)
# ------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Auth callback — must match Supabase dashboard redirect allowlist
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=https://codeguard.yourdomain.com/auth/callback

# ------------------------------
# 4. AI Configuration
# ------------------------------
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash
AI_API_KEY=your-gemini-api-key
AI_API_KEY_2=your-gemini-api-key-2
OLLAMA_URL=http://127.0.0.1:11434

# ------------------------------
# 5. Infrastructure (Internal)
# ------------------------------
# Redis — container name on the Docker network
REDIS_URL=redis://redis:6379

# Backend execution endpoint — internal Docker network (not public)
EXECUTE_URL=http://backend:5002/execute

# Docker Resource Limits
DOCKER_MEMORY_LIMIT=256m
DOCKER_CPU_LIMIT=1.0
DOCKER_PIDS_LIMIT=256
DOCKER_JAVA_MEMORY_LIMIT=512m

# Specify 'runsc' for gVisor sandbox on Production Linux servers
DOCKER_RUNTIME=

# Container Pool Sizes
DOCKER_POOL_SIZE_CPP=10
DOCKER_POOL_SIZE_PYTHON=10
DOCKER_POOL_SIZE_JAVA=5
DOCKER_POOL_SIZE_C=10

# High Concurrency Tuning
MAX_CONCURRENT_JOBS=250
WORKERS_PER_CONTAINER=20
